# Server
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRES_IN=7d

# Optional server-side Gemini key (only if operator wants server-side AI)
# GEMINI_API_KEY=

# Database
DB_PATH=./data/anime-recommender.db

# CORS
CORS_ORIGIN=http://localhost:5173

# Security & Proxy Settings
# ENCRYPTION_KEY=                 # MANDATORY in Production (secure 32-character string)
# TRUST_PROXY=false               # Set to '1' or 'true' behind reverse proxies (Render, Railway, etc.)
